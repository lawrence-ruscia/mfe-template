{
  "name": "mfe_template",
  "version": "0.0.1",
  "scripts": {
    "start": "cross-env NODE_ENV=development rspack serve",
    "build": "npm run clean && npm run typecheck && npm run lint && cross-env NODE_ENV=production rspack build",
    "build:dev": "cross-env NODE_ENV=development rspack build",
    "serve:dist": "rspack serve",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\""
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^2.13.0",
    "@eslint/js": "^9.39.3",
    "@rspack/cli": "~1.2.0",
    "@rspack/core": "~1.2.0",
    "@rspack/plugin-react-refresh": "~1.0.1",
    "@tailwindcss/postcss": "^4.0.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.1.0",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.2",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "postcss": "^8.2.1",
    "postcss-loader": "^8.0.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "react-refresh": "^0.14.0",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.0.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@module-federation/enhanced": "^0.8.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.575.0",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shadcn": "^3.8.5",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  }
}
